# Local-friendly defaults. Docker Compose overrides these where needed.
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1
LOG_LEVEL=info
API_AUTH_ENABLED=true
API_KEY=<set-a-long-random-api-key>
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/<database>
FRONTEND_API_BASE_URL=http://127.0.0.1:8000
FRONTEND_API_KEY=<same-value-as-api-key>
PROMETHEUS_API_KEY_FILE=secrets/prometheus_api_key
FEATURE_SCHEMA_PATH=artifacts/feature_schema.json
TREE_PREPROCESSOR_PATH=artifacts/tree_preprocessor.pkl
XGB_MODEL_PATH=artifacts/xgb_model.json
MLP_MODEL_PATH=artifacts/mlp_model.pt
MLP_PREPROCESSOR_PATH=artifacts/mlp_preprocessor.pkl
CATEGORY_MAPS_PATH=artifacts/category_maps.json
